# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (send /myid to @userinfobot to get it)
AUTHORIZED_USER_ID=123456789

# Local API port for TUI (default: 7777)
API_PORT=7777

# Copilot model (default: claude-sonnet-4.5)
COPILOT_MODEL=claude-sonnet-4.5

# Azure DevOps PR reviewer (optional)
# Organization URL, e.g. https://dev.azure.com/my-org
ADO_ORG_URL=
# Personal Access Token with Code (Read) and Pull Request Threads (Read & Write) scopes
ADO_PAT=
# Your ADO user GUID — required for casting votes (optional, comments work without it)
ADO_REVIEWER_ID=
# Comma-separated list of "Project/Repo" pairs to watch, e.g. MyProject/my-service,OtherProject/lib
ADO_REPOS=
# How often to poll for new PRs in milliseconds (default: 60000 = 1 minute)
ADO_POLL_INTERVAL_MS=60000
